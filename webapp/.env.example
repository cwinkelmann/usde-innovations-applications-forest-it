# Host port for the NiceGUI webapp
HOST_PORT=8080
# Host port for Label Studio
LS_PORT=8081

# Host directory that gets bind-mounted to /data inside the container.
# All sessions, outputs, model weights, and LS state live here.
HOST_DATA_DIR=/Volumes/storage/_tmp/usde

# Worker pool — leave "auto" to use one worker per visible GPU (CUDA), or a
# single worker on MPS / CPU. Set a number to override.
NUM_WORKERS=auto


# Per-device batch sizes. The webapp picks the entry matching DEVICE at
# runtime. BATCH_SIZE (no suffix) overrides all of them when set.
BATCH_SIZE_CUDA=16
BATCH_SIZE_MPS=2
BATCH_SIZE_CPU=8
BATCH_SIZE=

# Device selection — leave "auto" for cuda → mps → cpu preference.
DEVICE=auto

# MegaDetector checkpoint. Auto-downloaded from agentmorris/MegaDetector
# release on first run into $HOST_DATA_DIR/model_cache/megadetector/.
MD_WEIGHTS=md_v1000.0.0-larch.pt

# SpeciesNet classifier reference (Kaggle model path).
SPECIESNET_MODEL=kaggle:google/speciesnet/pyTorch/v4.0.2a/1

# Default Label Studio URL seeded into the webapp form. Use
# http://host.docker.internal:8081 if LS runs on the host outside compose.
LABEL_STUDIO_URL=http://labelstudio:8080
